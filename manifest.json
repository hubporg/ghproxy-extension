{
    "manifest_version": 3,
    "name": "GitHub Accelerator",
    "version": "1.0.0",
    "description": "智能 GitHub 下载加速器 - 拦截页面模式，完美兼容 IDM",
    "permissions": [
        "storage",
        "contextMenus",
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://api.akams.cn/*",
        "https://github.com/*",
        "https://*.github.com/*",
        "https://codeload.github.com/*",
        "https://raw.githubusercontent.com/*",
        "https://gist.githubusercontent.com/*",
        "*://github.com/*",
        "*://*.github.com/*",
        "*://codeload.github.com/*",
        "*://raw.githubusercontent.com/*",
        "*://gist.githubusercontent.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "GitHub Accelerator"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "intercept.html",
                "intercept.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}